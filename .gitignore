# Exclude everything in root except whitelisted items
/*
# Whitelist specific folders
!/grail-tracker/
!/screenshots/
# Whitelist specific files
!/.gitignore
!/README.md
!/package.json
!/build.js

# Explicitly ignore built HTML files
pd2-grail-tracker-v*.html

# Node modules
node_modules/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Environment files
.env
.env.local

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.backup
